

# Get your project ID from: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=a4dd35e09ae6dbb12fdaef67ddd629ec

# Rocky on rocky-backend: in dev mode getTradingBackendUrl() returns "" and
# calls go same-origin through vite.config.ts's /v1 and /fapi proxies (which
# default to https://api.rocky.exchange). Set VITE_PROXY_API_URL here to
# point dev at a different backend instead.
VITE_CONSOLE_WALLET_TARGET=combined
