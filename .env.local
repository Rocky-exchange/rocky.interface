
# Backend API URL (NestJS server for prediction markets)

# Feature Flags for API Data Sources
# Set to "true" to use zabnaraX backend instead of Multicall
VITE_USE_API_POSITIONS=true
VITE_USE_API_ORDERS=true
# Set to "true" to force prediction module mock data
VITE_PREDICTION_USE_MOCK=false

# Fee VIP：off | on/stable | random（合并原 USE_MOCK + MOCK_RANDOMIZE）
VITE_FEE_VIP_MOCK=off

# Referrals mock：off | on/stable
# Scene: empty | starter | gold
VITE_REFERRAL_MOCK=off
VITE_REFERRAL_MOCK_SCENE=starter

# Feature Flag for API Order Submission
# When enabled, orders are submitted through backend API instead of directly to chain
# This enables order tracking, validation, and additional business logic
VITE_USE_API_ORDER_SUBMIT=false

# App Configuration
VITE_APP_IS_HOME_SITE=false

# WalletConnect Configuration
# Get your project ID from: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=a4dd35e09ae6dbb12fdaef67ddd629ec

# Alchemy RPC Configuration
# Get your API key from: https://dashboard.alchemy.com/
# Required for RPC node access (Arbitrum, Avalanche, Base, BSC, Botanix, Optimism, Sepolia)
VITE_ALCHEMY_API_KEY=zEypV0LlNHwwqSw9sypOi


