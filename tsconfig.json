{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext", "WebWorker"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "sdk": ["./shared/sdk/index.ts"],
      "sdk/*": ["./shared/sdk/*"],
      "@/*": ["./*"],
      "@/modules/*": ["./modules/*"],
      "@/shared/*": ["./shared/*"],
      "@/app/*": ["./app/*"],
      "app/*": ["./app/*"],
      "components/*": ["./shared/components/*"],
      "config/*": ["./shared/config/*"],
      "domain/*": ["./modules/lighter/domain/*"],
      "fonts/*": ["./shared/fonts/*"],
      "img/*": ["./shared/img/*"],
      "lib/*": ["./shared/lib/*"],
      "locales/*": ["./shared/locales/*"],
      "modules/*": ["./modules/*"],
      "shared/*": ["./shared/*"],
      "styles/*": ["./shared/styles/*"],
      "typechain-types": ["./modules/lighter/contracts/typechain-types"],
      "typechain-types/*": ["./modules/lighter/contracts/typechain-types/*"],
      "typechain-types-stargate": ["./modules/lighter/contracts/typechain-types-stargate"],
      "typechain-types-stargate/*": ["./modules/lighter/contracts/typechain-types-stargate/*"]
    }
  },
  "include": ["src", "viem-override.d.ts"]
}
