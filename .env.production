# ============================================
# Production Environment Variables Template
# ============================================
# 生产环境配置文件模板
# 使用方法: 复制此文件为 .env.production 并根据实际情况修改
# ============================================

# ============================================
# 应用基础配置
# ============================================

# 应用版本号 (通常由构建脚本自动设置，一般不需要手动配置)
# VITE_APP_VERSION=

# 是否为首页站点 (true/false)
# VITE_IS_HOME_SITE=false
# VITE_APP_IS_HOME_SITE=false
VITE_USE_API_POSITIONS=true
VITE_USE_API_ORDERS=true
VITE_USE_API_ORDER_SUBMIT=false
VITE_APP_IS_HOME_SITE=false

VITE_SENTRY_DSN=https://88862fb979dfa71d30a4e196ab87216e@o4510735771566080.ingest.us.sentry.io/4510735775825920

# ============================================
# 后端 API 配置
# ============================================
VITE_PRIMIT_APP_ORIGIN = https://app.primit.io
# 后端服务 URL (XBlade 后端)
# 开发环境默认: http://localhost:8080
# 生产环境: https://api.primit.io
# Mainnet API
VITE_PROXY_API_URL=https://api.primit.io
# Sepolia API
VITE_PROXY_SEPOLIA_API_URL=https://api.primit.io

# WebSocket URLs
VITE_PROXY_WS_URL=wss://api.primit.io
VITE_PROXY_SEPOLIA_WS_URL=wss://api.primit.io
VITE_PRIMIT_APP_ORIGIN=https://app.primit.io
# ============================================
# WalletConnect 配置
# ============================================

# WalletConnect Project ID
# 从 https://cloud.walletconnect.com/ 获取您的 Project ID
VITE_WALLET_CONNECT_PROJECT_ID=a4dd35e09ae6dbb12fdaef67ddd629ec

# ============================================
# RPC 节点配置
# ============================================

# Alchemy API Key
# 从 https://dashboard.alchemy.com/ 获取您的 API Key
# 用于访问 Alchemy RPC 节点服务 (Arbitrum, Avalanche, Base, BSC, Botanix, Optimism, Sepolia)
VITE_ALCHEMY_API_KEY=zEypV0LlNHwwqSw9sypOi
